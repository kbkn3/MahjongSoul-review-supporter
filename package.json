{
  "name": "mahjong-soul-review-supporter",
  "displayName": "Mahjong soul review supporter",
  "version": "0.0.1",
  "description": "This extension retrieves information and automatically transfers to the screen to review the paihu of Mahjong Soul.",
  "author": "kbkn3",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.9.3",
    "plasmo": "0.85.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.36",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://game.mahjongsoul.com/*",
      "https://mahjongsoul.game.yo-star.com/*",
      "https://game.maj-soul.net/*",
      "https://game.maj-soul.com/*",
      "https://naga.dmv.nico/naga_report/order_form/",
      "https://mjai.ekyu.moe/"
    ],
    "permissions": [
      "scripting",
      "storage",
      "activeTab"
    ]
  }
}
